{
  "name": "beadsmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install",
    "doctor": "npx react-doctor@latest",
    "e2e:build": "tsx e2e/issue-list/scripts/build.ts",
    "e2e:issue-list:success": "tsx e2e/issue-list/scripts/run-scenario.ts issues",
    "e2e:issue-list:empty": "tsx e2e/issue-list/scripts/run-scenario.ts empty",
    "e2e:issue-list:atomic-switch": "tsx e2e/issue-list/scripts/run-scenario.ts atomic-switch",
    "e2e:issue-list": "pnpm e2e:issue-list:success && pnpm e2e:issue-list:empty",
    "e2e:issue-list:all": "pnpm e2e:issue-list && pnpm e2e:issue-list:atomic-switch",
    "test:e2e:issue-list": "pnpm e2e:build && pnpm e2e:issue-list"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "effect": "^3.21.4",
    "lucide-react": "^1.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "taurpc": "^1.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tailwindcss": "^1.3.3",
    "react-doctor": "^0.5.8",
    "tailwindcss": "^4.3.1",
    "tauri-agent-tools": "^0.8.0",
    "tsx": "4.22.4",
    "typescript": "~5.8.3",
    "ultracite": "7.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
